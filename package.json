{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3000",
    "generate": "nuxt generate",
    "preview": "nuxt preview --port 3000",
    "postinstall": "nuxt prepare",
    "lint": "npx ultracite check",
    "lint:fix": "npx ultracite fix",
    "format": "npx ultracite fix",
    "format:check": "npx ultracite check",
    "type-check": "nuxt typecheck",
    "clean": "nuxt cleanup",
    "check-all": "pnpm type-check && pnpm lint",
    "prepare": "husky",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env server/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@pinia/nuxt": "^1.0.0",
    "@tanstack/vue-table": "^8.21.3",
    "@unovis/ts": "^1.6.7",
    "@unovis/vue": "^1.6.7",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^0.541.0",
    "nuxt": "^4.4.8",
    "pinia": "^4.0.2",
    "postgres": "^3.4.9",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.39",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@internationalized/date": "^3.12.2",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.5.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.19",
    "shadcn-nuxt": "^2.7.4",
    "shadcn-vue": "^2.7.4",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "ultracite": "^7.9.4",
    "vue-tsc": "^3.3.7"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "npx ultracite fix",
      "npx ultracite check"
    ]
  }
}
