NODE_ENV=development

# Supabase 公开配置（前端可用）
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# @nuxtjs/supabase v2 推荐 KEY；ANON_KEY 仍可作为兼容别名
NUXT_PUBLIC_SUPABASE_KEY=your-publishable-or-anon-key
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# 服务端密钥（勿暴露到前端）
# v2 推荐 SECRET_KEY；SERVICE_KEY 仍可作为兼容别名
NUXT_SUPABASE_SECRET_KEY=your-secret-or-service-role-key
SUPABASE_SERVICE_KEY=your-secret-or-service-role-key

# 站点地址（本地开发默认 http://localhost:3000）
NUXT_PUBLIC_SITE_URL=http://localhost:3000
